{
  "name": "newsletter-digest",
  "version": "1.0.0",
  "description": "Pull newsletters from Gmail IMAP, summarize with Ollama, render digest.html",
  "type": "module",
  "main": "dist/src/index.js",
  "scripts": {
    "build": "tsc",
    "postbuild": "mkdir -p dist/test/fixtures && cp -R test/fixtures/. dist/test/fixtures",
    "start": "node dist/src/server.js",
    "digest:export": "node dist/src/digest.js",
    "test": "npm run build && node --test \"dist/test/*.test.js\""
  },
  "engines": {
    "node": ">=22"
  },
  "license": "MIT",
  "dependencies": {
    "@postlight/parser": "^2.2.3",
    "better-sqlite3": "^12.11.1",
    "dotenv": "^17.4.2",
    "imapflow": "^1.4.3",
    "mailparser": "^3.9.12",
    "nodemailer": "^9.0.3",
    "ollama": "^0.6.3",
    "pino": "^10.3.1",
    "pino-pretty": "^13.1.3"
  },
  "devDependencies": {
    "@types/better-sqlite3": "^7.6.13",
    "@types/mailparser": "^3.4.6",
    "@types/node": "^26.1.0",
    "@types/nodemailer": "^8.0.1",
    "typescript": "^6.0.3"
  }
}
